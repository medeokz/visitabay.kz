<a href="{full-link}">
    <div class="popular-news_bg e-resp">
        <img data-src="[xfvalue_image_url_poster]" src="{THEME}/dleimages/no_image.jpg">
    </div>
    <div class="popular-news_content">
        <p>{title}</p>
        <div class="popular-news_tags e-flex">
            <span><i class="far fa-eye me-1"></i> {views}</span>
        	<span><i class="far fa-calendar"></i> {date}</span>
        	<span><i class="far fa-comment-dots"></i> {comments-num}</span>
    	</div>
    </div>
</a>