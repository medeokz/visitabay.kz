<a href="{full-link}" class="home-hotel-card">
  <div class="home-hotel-card__bg">
    [xfgiven_poster][xfvalue_poster][/xfgiven_poster]
    [xfnotgiven_poster]<img src="{THEME}/images/hotels-hero.jpg" alt="{title}">[/xfnotgiven_poster]
  </div>
  <div class="home-hotel-card__content">
    <span class="home-hotel-card__tag">Гостиница в Семее</span>
    <h3 class="home-hotel-card__title">{title}</h3>
    <p class="home-hotel-card__meta">г. Семей</p>
    [xfgiven_price]<p class="home-hotel-card__price">от [xfvalue_price]</p>[/xfgiven_price]
  </div>
</a>
