<a href="{full-link}" class="hotel-card-h">
  [xfgiven_poster]
  <div class="hotel-card-h__bg-wrap">
    [xfvalue_poster]
  </div>
  [/xfgiven_poster]
  [xfnotgiven_poster]
  <div class="hotel-card-h__bg-wrap">
    <img src="https://images.pexels.com/photos/258154/pexels-photo-258154.jpeg?auto=compress&cs=tinysrgb&w=1200" alt="{title}">
  </div>
  [/xfnotgiven_poster]
  <div class="hotel-card-h__content">
    <div class="hotel-card-h__info">
      <h3>{title}</h3>
      <div class="location">
        <img src="{THEME}/images/18128_327.svg" alt="location icon">
        <span>озеро Алаколь, Казахстан</span>
      </div>
    </div>
    <div class="hotel-card-h__price">
      [xfgiven_price]<strong>[xfvalue_price]</strong>[/xfgiven_price]
      <span>{short-story}</span>
    </div>
  </div>
</a>

