<a href="{full-link}" class="alakol-card">
  <div class="alakol-card__image">
    [xfgiven_poster][xfvalue_poster][/xfgiven_poster]
    [xfnotgiven_poster]<img src="https://images.pexels.com/photos/258154/pexels-photo-258154.jpeg?auto=compress&cs=tinysrgb&w=1200" alt="{title}">[/xfnotgiven_poster]
  </div>
  <div class="alakol-card__content">
    <h3 class="alakol-card__title">{title}</h3>
    <p class="alakol-card__meta">озеро Алаколь, Казахстан</p>
    [xfgiven_price]<p class="alakol-card__price">от [xfvalue_price]</p>[/xfgiven_price]
  </div>
</a>

