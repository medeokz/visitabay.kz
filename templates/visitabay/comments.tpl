<div class="dle-comm_item">
    <div class="dle-comm_meta e-flex">
        <div class="dle-comm_user">
            <img src="{foto}" alt="{login}">
            <div>[not-group=5]{author}[/not-group][group=5]<a>{login}</a>[/group]<span>{date}</span></div>
        </div>
        [reply]Ответить[/reply]
        <div class="dle-comm_rating">
            [rating-plus]<i class="fa-regular fa-thumbs-up"></i> {likes}[/rating-plus]
            <span>{ratingscore}</span>
        	[rating-minus]<i class="fa-regular fa-thumbs-down"></i> {dislikes}[/rating-minus]
        </div>
        [not-group=5]
        <div class="dle-comm_det">
            <i class="fa-regular fa-ellipsis"></i>
            <div>[com-edit]Редактировать[/com-edit][com-del]Удалить[/com-del]</div>
        </div>
        [/not-group]
    </div>
    <div class="dle-comm_text">{comment}</div>
</div>