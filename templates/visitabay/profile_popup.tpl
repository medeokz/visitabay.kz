<div class="dle-use">
    <div class="dle-use_bg e-cover"><img src="https://images.wallpapershq.com/wallpapers/1646/wallpaper_1646_2048x1152.jpg"/></div>
    <div class="dle-use_content e-flex">
        <div class="dle-use_avatar e-cover"><img src="{foto}"/></div>
        <div class="dle-use_title">
            <h2>{fullname}</h2>
            <span>{status}</span>
        </div>
    </div>   
</div>
<ul class="dle-use_info section e-grid2">
    <li><span>Регистрация:</span> {registration}</li>
    <li><span>Заходил(а):</span> {lastdate}</li>
    [news-num]<li>{news}</li>[/news-num]
    [comm-num]<li>{comments}</li>[/comm-num]
</ul>