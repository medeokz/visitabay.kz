<a href="{full-link}" class="hotel-card-h" data-categories="center embankment family business">
  [xfgiven_poster]
  <div class="hotel-card-h__bg-wrap">
    [xfvalue_poster]
  </div>
  [/xfgiven_poster]
  [xfnotgiven_poster]
  <div class="hotel-card-h__bg-wrap">
    <img src="{THEME}/images/hotels-hero.jpg" alt="{title}">
  </div>
  [/xfnotgiven_poster]
  <div class="hotel-card-h__content">
    <div class="hotel-card-h__info">
      <h3>{title}</h3>
      <div class="location">
        <img src="{THEME}/images/18128_327.svg" alt="location icon">
        <span>г. Семей</span>
      </div>
    </div>
    <div class="hotel-card-h__price">
      <strong>[xfvalue_price]</strong>
      <span>{short-story}</span>
    </div>
  </div>
</a>
