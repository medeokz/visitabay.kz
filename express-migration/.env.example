PORT=4000
NODE_ENV=development
PUBLIC_BASE_PATH=
# Только путь, без домена (не вставляйте https://... — или будет исправлено автоматически).
# ASSET_ABSOLUTE_URLS=1  — абсолютные URL CSS в <head> даже вне production
TRUST_PROXY=

# Comma separated allowlist for browser CORS origins (leave empty to allow all)
# CORS_ORIGIN=https://visitabay.kz,https://www.visitabay.kz

# REQUIRED in production: at least 24 chars
SESSION_SECRET=change-this-to-a-long-random-secret
# Optional session cookie name
SESSION_COOKIE_NAME=visitabay.sid
# Если админка «выкидывает» после логина за HTTPS, поставьте TRUST_PROXY=1; при необходимости COOKIE_SECURE=0
# COOKIE_SECURE=0

DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=visitabay
DB_PREFIX=abay

# БД модуля гостиниц (карточки «Где остановиться» на постах). По умолчанию visitabay_hotels, те же хост/пользователь, что и DB_*.
# HOTELS_DB_NAME=visitabay_hotels
# HOTELS_DB_USER=
# HOTELS_DB_PASSWORD=

# --- Phusion Passenger / cPanel ---
# Application root в панели: каталог express-migration (где package.json).
# Startup file: src/server.js (см. Passengerfile.json).
# Обязательно задайте SESSION_SECRET и DB_* в переменных окружения панели ИЛИ положите .env в express-migration/
