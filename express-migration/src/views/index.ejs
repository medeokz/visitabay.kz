          <li><a href="#jekoturizm"><%= hm.ecoH1 %><img src="<%= themeBase %>/images/18001_114.svg" alt=""></a></li>
          <li><a href="#sakralnyi"><%= hm.sacredH1 %><img src="<%= themeBase %>/images/18001_114.svg" alt=""></a></li>
          <li><a href="<%= bp %>/category/abai-zholy"><%= hm.abaiZholy %><img src="<%= themeBase %>/images/18001_114.svg" alt=""></a></li>
