<!doctype html>
<% var _ixLang = typeof lang !== "undefined" && lang ? lang : "ru"; %>
<% var bp = (typeof basePath === "string" && basePath) ? basePath : ""; %>
<html lang="<%= _ixLang === 'en' ? 'en' : _ixLang === 'ru' ? 'ru' : 'kk' %>">
<head>
  <%- include("partials/head") %>
  <title>Visit Abay</title>
</head>
<body>
<%
  var _pack = locals.menuFooter || locals.defaultMenuFooter || {};
  var hm = _pack.home || {};
%>
  <div id="loader">
    <div class="logo">VISITABAY</div>
    <div class="progress"></div>
  </div>
  <script>
    (function () {
      function hideLoader() {
        var loader = document.getElementById("loader");
        var content = document.getElementById("content");
        if (loader) {
          loader.classList.add("hidden");
          loader.style.display = "none";
        }
        if (content) {
          content.style.display = "block";
        }
        document.body.style.overflow = "auto";
      }

      document.addEventListener("DOMContentLoaded", function () {
        setTimeout(hideLoader, 1400);
      });
      window.addEventListener("load", function () {
        setTimeout(hideLoader, 100);
      });
      setTimeout(hideLoader, 5000);
    })();
  </script>
  <div class="wrapper" id="content">
  <%- include("partials/header") %>
  <div class="container">
  <div class="vis-hero">
    <div class="swiper-wrapper">
      <div class="vis-hero_item swiper-slide">
        <div class="vis-hero_title"><%= hm.heroLine1 %> <br> <%= hm.heroLine2 %></div>
        <a href="#beach"><%= hm.heroCta %></a>
        <ul class="vis-hero_type">
          <li><a href="#beach"><%= hm.beachH1 %><img src="<%= themeBase %>/images/18001_114.svg" alt=""></a></li>
          <li><a href="#jekoturizm"><%= hm.ecoH1 %><img src="<%= themeBase %>/images/18001_114.svg" alt=""></a></li>
          <li><a href="#sakralnyi"><%= hm.sacredH1 %><img src="<%= themeBase %>/images/18001_114.svg" alt=""></a></li>
          <li><a href="<%= bp %>/category/abai-zholy"><%= hm.abaiZholy %><img src="<%= themeBase %>/images/18001_114.svg" alt=""></a></li>
        </ul>
        <div class="vis-hero_bg e-cover">
          <div data-vbg="<%= themeBase %>/video/video-hero.mp4" data-vbg-muted="true" data-vbg-mobile="true" data-vbg-start-at="0" data-vbg-mute-button="false" data-vbg-load-background="false"></div>
        </div>
      </div>
      <div class="vis-hero_item swiper-slide">
