    <section class="home-alakol">
      <div class="container">
        <div class="home-alakol__grid">
          <a href="<%= bp %>/baza-alakol" class="alakol-card">
            <div class="alakol-card__image">
              <% var _alakolPromoImg = 'https://upload.wikimedia.org/wikipedia/commons/thumb/e/ec/Alakol_Lake_ESA365539.jpg/3840px-Alakol_Lake_ESA365539.jpg'; %>
              <img
                src="<%= _alakolPromoImg %>"
                srcset="https://upload.wikimedia.org/wikipedia/commons/thumb/e/ec/Alakol_Lake_ESA365539.jpg/1920px-Alakol_Lake_ESA365539.jpg 1920w,
https://upload.wikimedia.org/wikipedia/commons/thumb/e/ec/Alakol_Lake_ESA365539.jpg/3840px-Alakol_Lake_ESA365539.jpg 2880w"
                sizes="(max-width: 768px) 100vw, 50vw"
                alt="<%= hm.alakolPromoAlt %>"
                loading="eager"
                decoding="async"
                width="2880"
                height="2914"
                onerror="this.onerror=null;this.src='https://upload.wikimedia.org/wikipedia/commons/thumb/e/ec/Alakol_Lake_ESA365539.jpg/1920px-Alakol_Lake_ESA365539.jpg'"
              >
            </div>
            <div class="alakol-card__content">
              <h3 class="alakol-card__title"><%= hm.alakolCardTitle %></h3>
              <p class="alakol-card__meta"><%= hm.alakolCardMeta %></p>
              <p class="alakol-card__price"><%= hm.alakolCardBlurb %></p>
            </div>
