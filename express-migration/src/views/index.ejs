          </div>
        </div>
      </div>
    </section>

    <br><br>

    <%
      var ixLang = typeof lang !== "undefined" && lang ? lang : "ru";
      var ixEvHead = {
        kk: {
          h2: "Жақын күндегі оқиғалар (Семей)",
          all: "Барлық оқиғалар →",
          filterAll: "Барлығы",
          filterToday: "Бүгін",
          filterTomorrow: "Ертең",
          filterWeekend: "Демалыс",
          filterEmpty: "Осы фильтр бойынша оқиғалар жоқ."
        },
        ru: {
          h2: "События в ближайшие дни в Семей",
          all: "Все события →",
          filterAll: "Все",
          filterToday: "Сегодня",
          filterTomorrow: "Завтра",
          filterWeekend: "Выходные",
          filterEmpty: "Нет событий для выбранного фильтра."
        },
        en: {
          h2: "Upcoming events in Semey",
          all: "All events →",
          filterAll: "All",
          filterToday: "Today",
          filterTomorrow: "Tomorrow",
          filterWeekend: "Weekend",
          filterEmpty: "No events for this filter."
        }
      };
      var ixEvT = ixEvHead[ixLang] || ixEvHead.ru;
      var ixDateTag = ixLang === "kk" ? "kk-KZ" : ixLang === "en" ? "en-US" : "ru-RU";
    %>
    <div class="vis-events" data-home-events-root>
      <div class="vis-events_head">
        <h2><%= ixEvT.h2 %></h2>
        <a href="<%= bp %>/sobytija-semey" class="vis-events-all-link vis-sak_title-pill"><%= ixEvT.all %><i class="fa fa-chevron-right"></i></a>
      </div>
      <div class="event-filters">
        <button type="button" class="filter-btn active" data-period="all"><%= ixEvT.filterAll %></button>
        <button type="button" class="filter-btn" data-period="today"><%= ixEvT.filterToday %></button>
        <button type="button" class="filter-btn" data-period="tomorrow"><%= ixEvT.filterTomorrow %></button>
        <button type="button" class="filter-btn" data-period="weekend"><%= ixEvT.filterWeekend %></button>
      </div>
      <p class="vis-events__filter-empty node-message" hidden><%= ixEvT.filterEmpty %></p>
      <div class="events-grid">
        <% (eventPosts || []).forEach(function(p){ %>
          <% var ixEvIso = p.event_date ? String(p.event_date).slice(0, 10) : ""; %>
          <a class="event-card" href="<%= bp %>/sobytija-semey/<%= p.slug %>" data-event-date="<%= ixEvIso %>">
            <div class="event-card-bg"><% if (p.poster_url) { %><img src="<%= p.poster_url %>" alt="<%= p.title %>"><% } %></div>
            <div class="event-card-content">
              <div class="event-details">
                <h4><%= p.title %></h4>
                <div class="event-location">
                  <img src="<%= themeBase %>/images/18017_204.svg" alt="">
                  <span><%= p.location || "" %></span>
                </div>
              </div>
              <div class="event-price">
                <% if (p.price) { %><span class="price-amount"><%= p.price %> KZT</span><% } %>
                <span class="price-person"><% if (p.event_date) { %><%= new Date(p.event_date).toLocaleDateString(ixDateTag) %><% } %></span>
              </div>
            </div>
          </a>
        <% }) %>
      </div>
    </div>
    <script>
      (function () {
        var root = document.querySelector("[data-home-events-root]");
        if (!root) return;
        var grid = root.querySelector(".events-grid");
        if (!grid) return;
        var cards = grid.querySelectorAll("a.event-card[data-event-date]");
        var emptyEl = root.querySelector(".vis-events__filter-empty");
        var buttons = root.querySelectorAll(".event-filters .filter-btn[data-period]");

        function toLocalDateOnly(value) {
          if (!value) return null;
          var src = String(value).slice(0, 10);
          var m = /^(\d{4})-(\d{2})-(\d{2})$/.exec(src);
          if (!m) return null;
          return new Date(Number(m[1]), Number(m[2]) - 1, Number(m[3]));
        }
        function plusDays(date, days) {
          return new Date(date.getFullYear(), date.getMonth(), date.getDate() + days);
        }
        function matchesPeriod(eventDateRaw, period) {
          var eventDate = toLocalDateOnly(eventDateRaw);
          if (!eventDate) return false;
          var today = toLocalDateOnly(new Date());
          if (!today) return false;
          if (period === "today") return eventDate.getTime() === today.getTime();
          if (period === "tomorrow") return eventDate.getTime() === plusDays(today, 1).getTime();
          if (period === "weekend") {
            var maxDate = plusDays(today, 7);
            var day = eventDate.getDay();
            return eventDate >= today && eventDate <= maxDate && (day === 0 || day === 6);
          }
          return true;
        }

        function applyPeriod(period) {
          var p = period === "all" ? "" : period;
          var shown = 0;
          cards.forEach(function (card) {
            var d = card.getAttribute("data-event-date") || "";
            var ok = !p || matchesPeriod(d, p);
            card.style.display = ok ? "" : "none";
            if (ok) shown += 1;
          });
          if (emptyEl) {
            emptyEl.hidden = !p || shown > 0 || cards.length === 0;
          }
          buttons.forEach(function (btn) {
            var bp = btn.getAttribute("data-period") || "";
            btn.classList.toggle("active", bp === (period || "all"));
          });
        }

        root.querySelector(".event-filters").addEventListener("click", function (e) {
          var btn = e.target.closest(".filter-btn[data-period]");
          if (!btn || !root.contains(btn)) return;
          applyPeriod(btn.getAttribute("data-period") || "all");
        });
      })();
    </script>
  </div>
  </div>
  <%- include("partials/footer") %>
</div>
</body>
</html>
