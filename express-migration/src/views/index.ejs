    </div>

    <section class="home-hotels">
      <div class="container">
        <div class="home-hotels__grid">
          <% (hotelPosts || []).forEach(function(p){ %>
            <% var hotelHref = p.hotelUrl || (p.alt_name ? ("/post/" + p.alt_name) : "#"); %>
            <% var hotelTitle = p.name || p.title || ""; %>
            <% var hotelPoster = p.cardImage || p.poster || ""; %>
            <% var hotelLocation = p.location || hm.hotelCityShort; %>
            <% var hotelPrice = p.price || (p.xfields && p.xfields.price) || ""; %>
            <a href="<%= hotelHref %>" class="home-hotel-card">
              <div class="home-hotel-card__bg"><% if (hotelPoster) { %><img src="<%= hotelPoster %>" alt="<%= hotelTitle %>"><% } %></div>
              <div class="home-hotel-card__content">
                <span class="home-hotel-card__tag"><%= hm.hotelCardTag %></span>
                <h3 class="home-hotel-card__title"><%= hotelTitle %></h3>
                <% var _locNorm = String(hotelLocation || "").trim(); var _titleNorm = String(hotelTitle || "").trim(); %>
                <% if (_locNorm && _titleNorm.toLowerCase() !== _locNorm.toLowerCase()) { %>
                <p class="home-hotel-card__meta"><%= hotelLocation %></p>
                <% } %>
                <% if (hotelPrice) { %><p class="home-hotel-card__price"><%= hm.hotelPriceFrom %> <%= hotelPrice %></p><% } %>
