<!doctype html>
<%
  var eiLang = typeof lang !== "undefined" && lang ? lang : "ru";
  var eiDateTag = typeof dateLocale !== "undefined" && dateLocale ? dateLocale : "ru-RU";
  var eiUi = {
    kk: {
      titleSuffix: " — Семей оқиғалары",
      back: "← Оқиғаларға",
      about: "ІС-ШАРА ТУРАЛЫ",
      contacts: "БАЙЛАНЫС",
      price: "Баға:",
      route: "МАРШРУТ САЛУ",
      ticket: "БИЛЕТ САТЫП АЛУ",
      mapNote: "Карта: Google, маршрут: 2GIS",
      rec: "Ұсынылатындар"
    },
    ru: {
      titleSuffix: " — События Семей",
      back: "← К событиям",
      about: "О СОБЫТИИ",
      contacts: "КОНТАКТЫ",
      price: "Цена:",
      route: "ПОСТРОИТЬ МАРШРУТ",
      ticket: "КУПИТЬ БИЛЕТ",
      mapNote: "Карта на сайте: Google, маршрут: 2GIS",
      rec: "Рекомендуем посетить"
    },
    en: {
      titleSuffix: " — Semey events",
      back: "← All events",
      about: "ABOUT THE EVENT",
      contacts: "CONTACTS",
      price: "Price:",
      route: "BUILD ROUTE",
      ticket: "BUY TICKET",
      mapNote: "Map: Google; route: 2GIS",
      rec: "You may also like"
    }
  };
  var eiT = eiUi[eiLang] || eiUi.ru;
%>
<html lang="<%= eiLang === 'kk' ? 'kk' : eiLang === 'en' ? 'en' : 'ru' %>">
<head>
  <%- include("partials/head") %>
  <title><%= event.title %><%= eiT.titleSuffix %></title>
</head>
<body>
  <%- include("partials/header") %>
  <section id="story" class="container">
    <% var recEvents = (typeof recommendedEvents !== "undefined" && recommendedEvents) ? recommendedEvents : []; %>
    <p class="node-back"><a href="/sobytija-semey"><%= eiT.back %></a></p>

    <div class="post-hero">
      <div class="post-hero__media e-cover">
        <% if (event.poster_url) { %>
          <div class="post-hero__slides">
            <div class="post-hero__slide is-active">
              <img src="<%= event.poster_url %>" alt="<%= event.title %>">
            </div>
          </div>
        <% } %>
        <h1 class="post-hero__title"><%= event.title %></h1>
      </div>
    </div>

    <br>

    <div class="contacts-info_item vis-event-about">
      <div class="contacts-info_content">
        <% if (event.price) { %>
          <p class="vis-event-price-line"><strong><%= eiT.price %></strong> <%= event.price %> KZT</p>
        <% } %>
        <h2 class="contacts-title" style="margin-bottom: 6px !important;"><%= eiT.about %></h2>
      </div>
      <div class="contacts-info_bg e-cover vis-event-about__ghost" aria-hidden="true"></div>
    </div>
    <div class="story-content vis-event-story-content">
      <% if (event.summary) { %><p class="contacts-details"><%= event.summary %></p><% } %>
      <% if (event.description) { %><div class="story-body contacts-details"><%- event.description %></div><% } %>
    </div>

    <br><br><br>

    <div class="contacts-info_item">
      <div class="contacts-info_content">
        <h2 class="contacts-title"><%= eiT.contacts %></h2>
        <%
          var routeLink = String(event.route_link || "").trim();
          var mapQuery = String(event.address || event.location || event.title || "").trim();
          var is2gis = /(?:^https?:\/\/)?(?:go\.)?2gis\.(?:com|kz)\//i.test(routeLink);
          var isGoogleEmbed = /google\.com\/maps\/embed/i.test(routeLink);
          var mapSrc = "";
          if (isGoogleEmbed) {
            mapSrc = routeLink;
          } else if (mapQuery) {
            mapSrc = "https://www.google.com/maps?q=" + encodeURIComponent(mapQuery) + "&output=embed";
          }
        %>
        <address class="contacts-details">
          <%= event.location || "Семей" %>
          <% if (event.address) { %><br><%= event.address %><% } %>
          <% if (event.event_date || event.event_time) { %>
            <br><%= event.event_date || "" %> <%= event.event_time || "" %>
          <% } %>
        </address>
        <% if (routeLink) { %>
          <a href="<%= routeLink %>" class="promo-button" target="_blank" rel="noopener">
            <span><%= eiT.route %></span>
            <img src="<%= themeBase %>/images/18128_319.svg" alt="arrow right">
          </a>
        <% } %>
        <% if (event.ticket_url) { %>
          <a href="<%= event.ticket_url %>" class="promo-button" target="_blank" rel="noopener" style="margin-top:10px;">
            <span><%= eiT.ticket %></span>
            <img src="<%= themeBase %>/images/18128_319.svg" alt="arrow right">
          </a>
        <% } %>
      </div>
      <div class="contacts-info_bg e-cover">
        <% if (mapSrc) { %>
          <iframe
            src="<%= mapSrc %>"
            width="600"
            height="450"
            style="border:0;"
            allowfullscreen=""
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
          ></iframe>
          <% if (is2gis) { %>
            <div class="node-muted" style="position:absolute;left:12px;bottom:10px;z-index:3;background:rgba(255,255,255,.88);padding:4px 8px;border-radius:8px;">
              <%= eiT.mapNote %>
            </div>
          <% } %>
        <% } else if (event.poster_url) { %>
          <img src="<%= event.poster_url %>" alt="<%= event.title %>">
        <% } %>
      </div>
    </div>
  </section>

  <br><br><br>

  <% if (recEvents.length) { %>
  <div class="container">
    <div class="vis-blog vis-events">
      <h2><%= eiT.rec %></h2>
      <div class="events-grid">
        <% recEvents.forEach(function(p){ %>
          <a class="event-card" href="/sobytija-semey/<%= p.slug %>">
            <div class="event-card-bg"><% if (p.poster_url) { %><img src="<%= p.poster_url %>" alt="<%= p.title %>"><% } %></div>
            <div class="event-card-content">
              <div class="event-details">
                <h4><%= p.title %></h4>
                <div class="event-location">
                  <img src="<%= themeBase %>/images/18017_204.svg" alt="">
                  <span><%= p.location || "Семей" %></span>
                </div>
                <% if (p.address) { %><p class="event-address"><%= p.address %></p><% } %>
              </div>
              <div class="event-price">
                <% if (p.price) { %><span class="price-amount"><%= p.price %> KZT</span><% } %>
                <% if (p.event_date) { %><span class="node-muted" style="font-size:12px;display:block;margin-top:4px;"><%= new Date(p.event_date).toLocaleDateString(eiDateTag) %> <%= p.event_time || "" %></span><% } %>
              </div>
            </div>
          </a>
        <% }) %>
      </div>
    </div>
  </div>
  <% } %>

  <br><br><br>
  <%- include("partials/footer") %>
</body>
</html>
