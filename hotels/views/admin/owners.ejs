<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Хозяева гостиниц</title>
  <link rel="stylesheet" href="<%= typeof basePath !== 'undefined' ? basePath : '' %>/css/style.css">
</head>
<body class="admin-page">
  <% var bp = (typeof basePath !== 'undefined' ? basePath : ''); var adm = typeof adminWebRoot !== 'undefined' ? adminWebRoot : (bp + '/admin'); %>
  <header class="admin-header">
    <h1>Хозяева гостиниц</h1>
    <a href="<%= adm %>">← К гостиницам</a>
    <a href="<%= adm %>/bookings">Бронирования</a>
    <a href="<%= adm %>/logout">Выйти</a>
  </header>
  <main class="admin-main">
    <% if (typeof error !== 'undefined' && error) { %><p class="error"><%= error %></p><% } %>
    <% if (ok) { %><p class="success"><%= ok === 'rejected' ? 'Заявка отклонена.' : 'Хозяин добавлен.' %></p><% } %>

    <% if (typeof pendingRequests !== 'undefined' && pendingRequests.length) { %>
    <h2>Заявки на регистрацию (модерация)</h2>
    <table class="admin-table" style="margin-bottom: 2rem;">
      <thead>
        <tr>
          <th>Логин</th>
          <th>ФИО / организация</th>
          <th>Телефон</th>
          <th>Гостиница</th>
          <th>Сообщение</th>
          <th>Дата</th>
          <th>Действия</th>
        </tr>
      </thead>
      <tbody>
        <% pendingRequests.forEach(function(r) { %>
          <tr>
            <td><%= r.login %></td>
            <td><%= r.name || '—' %></td>
            <td><%= r.phone || '—' %></td>
            <td><%= r.hotel_name || '—' %></td>
            <td><%= (r.message || '').slice(0, 80) %><%= (r.message && r.message.length > 80) ? '…' : '' %></td>
            <td><%= r.created_at ? new Date(r.created_at).toLocaleString('ru') : '—' %></td>
            <td>
              <form method="post" action="<%= adm %>/owners/approve/<%= r.id %>" style="display:inline;">
                <button type="submit">Одобрить</button>
              </form>
              <form method="post" action="<%= adm %>/owners/reject/<%= r.id %>" style="display:inline; margin-left: 0.5rem;">
                <button type="submit" style="background: #999;">Отклонить</button>
              </form>
            </td>
          </tr>
        <% }); %>
      </tbody>
    </table>
    <% } %>

    <h2>Добавить хозяина вручную</h2>
    <form method="post" action="<%= adm %>/owners" class="hotel-form" style="max-width: 400px;">
      <label>Логин <input type="text" name="login" required></label>
      <label>Пароль <input type="password" name="password" required></label>
      <div class="form-actions">
        <button type="submit">Добавить</button>
      </div>
    </form>

    <h2 style="margin-top: 2rem;">Список хозяев</h2>
    <table class="admin-table">
      <thead>
        <tr>
          <th>ID</th>
          <th>Логин</th>
          <th>Создан</th>
        </tr>
      </thead>
      <tbody>
        <% if (owners && owners.length) { %>
          <% owners.forEach(function(o) { %>
            <tr>
              <td><%= o.id %></td>
              <td><%= o.login %></td>
              <td><%= o.created_at ? new Date(o.created_at).toLocaleDateString('ru') : '—' %></td>
            </tr>
          <% }); %>
        <% } else { %>
          <tr><td colspan="3">Нет хозяев. Добавьте первого выше.</td></tr>
        <% } %>
      </tbody>
    </table>
  </main>
</body>
</html>
