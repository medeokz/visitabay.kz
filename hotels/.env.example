PORT=3000
NODE_ENV=development

# MySQL (XAMPP: root без пароля по умолчанию)
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=visitabay_hotels

# Админ: логин и пароль (пароль будет захэширован при первом запуске)
ADMIN_LOGIN=admin
ADMIN_PASSWORD=admin123

SESSION_SECRET=your-secret-key-change-in-production

# Если приложение отдаётся по подпути (напр. за прокси), укажите базовый путь без слэша в конце:
# BASE_PATH=/visitabay.kz/hotels

# Вместе с express-migration (порт 4000): префикс страниц админки гостиниц в браузере (редиректы и формы)
# BROWSER_ADMIN_BASE=/hotels-admin

# Письма после бронирования (если не задано — уведомления по почте не отправляются)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=noreply@visitabay.kz

# Web Push для уведомлений владельцам (сгенерировать: npx web-push generate-vapid-keys)
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_MAILTO=admin@visitabay.kz

# WhatsApp через Twilio (уведомления гостю и хозяину после бронирования)
# Регистрация: https://www.twilio.com/console. WhatsApp Sandbox: https://www.twilio.com/docs/whatsapp/sandbox
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
